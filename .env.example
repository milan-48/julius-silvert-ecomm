# No required environment variables for this app.
# Stock saves use a bcrypt hash embedded in `app/api/catalog/inventory/save/route.js`.

# Optional: `/qa` loads from Google Sheets CSV export (defaults to project sheet if unset).
# Sheet must be shared: “Anyone with the link” → Viewer (or Publish to web).
# GOOGLE_SHEETS_QA_ID=1qQuhOC5pBHpO_qB72647n8iZR1RXE4odd84Pf68VSxg
# GOOGLE_SHEETS_QA_GID=0
#
# “Open in Sheet” links use the editor URL with a different tab gid than CSV export.
# GOOGLE_SHEETS_QA_EDIT_GID=1273434837
#
# Optional CSV column “Sheet Row” (1-based editor row on that tab) when SN ≠ sheet order.
